# Same profile-selection convention used by the fscom-cart Spring backend.
SPRING_PROFILES_ACTIVE=qa
NODE_ENV=qa

# Private dashboard storage (separate from the shared Cart database).
# Leave unset to keep dashboard data in data/scripts.json.
# DATABASE_URL=postgresql://dashboard_user:dashboard_password@localhost:5432/integration_dashboard

# fscom-cart read-only preview. Host/database/schema/user come from the selected
# Spring profile. The deployed container reads the same Config Tree secret mount.
FSCOM_CART_DATABASE_PASSWORD_FILE=/etc/secrets/fscart-secret/secret.spring.datasource.password
# For authorized local development only:
# FSCOM_CART_DATABASE_PASSWORD=
# Optional overrides matching Spring datasource configuration:
# SPRING_DATASOURCE_URL=jdbc:postgresql://host:5432/database?currentSchema=fscart
# SPRING_DATASOURCE_USERNAME=fscartapp
# SPRING_DATASOURCE_PASSWORD=

HOST=127.0.0.1
PORT=8000
# Deployment ingress prefix; leave blank for local http://127.0.0.1:8000/.
# BASE_PATH=/integration-dashboard
